{
  "$comment": "Record the edit in PROJECT.md. Best-effort: log_edit always exits 0, so this never fails the edit (it already vets + tests).",
  "id": "edit_file.log",
  "kind": "action",
  "tool": "log_edit",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "request", "path": ".", "as": "summary" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "summary": "{{ summary }}" },
  "on_success": "edit_file.done",
  "on_failure": "edit_file.done"
}
