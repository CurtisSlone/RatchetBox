{
  "$comment": "Repair: regenerate the file given the vet/test diagnostics + the existing API + the previous attempt. Bounded - one fix, then recheck.",
  "id": "add_file.fix",
  "kind": "generate",
  "prompt": "./prompt.md",
  "inputs": [
    { "from": "request", "path": ".", "as": "request" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "add_file.api", "path": ".", "as": "api" },
    { "from": "add_file.generate", "path": ".", "as": "prev", "max_chars": 5000 },
    { "from": "add_file.check", "path": ".", "as": "errors", "max_chars": 2500 }
  ],
  "on_success": "add_file.recheck",
  "on_failure": "add_file.fail"
}
