{
  "id": "add_file.recheck",
  "kind": "action",
  "tool": "stage_check",
  "inputs": [
    { "from": "$workspace", "path": ".", "as": "proj" },
    { "from": "path", "path": ".", "as": "path" },
    { "from": "add_file.fix", "path": ".", "as": "code" }
  ],
  "body": { "proj": "{{ proj }}", "path": "{{ path }}", "code": "{{ code }}" },
  "on_success": "add_file.register",
  "on_failure": "add_file.fail"
}
